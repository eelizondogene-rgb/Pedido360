@model IEnumerable<Pedido360.ViewModels.ClienteListItemViewModel>
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Clientes</h1>
        <p class="text-muted mb-0">CRUD sobre <code>dbo.Clientes</code> usando Entity Framework Core.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Nuevo cliente</a>
</div>

@* Barra de busqueda por nombre o cedula *@
<form method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text"
               name="buscar"
               value="@ViewBag.Buscar"
               class="form-control"
               placeholder="Buscar por nombre o cedula..." />
        <button type="submit" class="btn btn-outline-secondary">Buscar</button>
        @if (!string.IsNullOrWhiteSpace(ViewBag.Buscar as string))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Limpiar</a>
        }
    </div>
</form>

<div class="table-card p-3">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Cedula</th>
                <th>Correo</th>
                <th>Telefono</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Cliente.Id</td>
                <td>@item.Cliente.Nombre</td>
                <td>@item.Cliente.Cedula</td>
                <td>@item.Cliente.Correo</td>
                <td>@item.Cliente.Telefono</td>
                <td>
                    @if (item.Cliente.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary"
                       asp-action="Details"
                       asp-route-id="@item.Cliente.Id">Ver</a>
                    <a class="btn btn-sm btn-outline-secondary"
                       asp-action="Edit"
                       asp-route-id="@item.Cliente.Id">Editar</a>
                    <a class="btn btn-sm btn-outline-danger"
                       asp-action="Delete"
                       asp-route-id="@item.Cliente.Id">Eliminar</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Buscar as string))
                    {
                        <span>No se encontraron clientes con ese criterio de busqueda.</span>
                    }
                    else
                    {
                        <span>No hay clientes registrados aun.</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
